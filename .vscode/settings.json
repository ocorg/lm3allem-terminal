{
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,
  "editor.quickSuggestions": {
    "strings": true
  },
  "tailwindCSS.includeLanguages": {
    "plaintext": "html"
  },
  "i18n-ally.localesPaths": [
    "messages",
    "lib/i18n"
  ],
  "i18n-ally.locales": ["fr", "ar"],
  "i18n-ally.sourceLanguage": "fr",
  "i18n-ally.displayLanguage": "fr"
}